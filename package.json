{
  "name": "consilium",
  "version": "0.1.0",
  "description": "Multi-agent AI orchestration app — Council of Advisors",
  "main": "./dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:debug": "electron-vite dev -- --remote-debugging-port=9333",
    "build": "electron-vite build",
    "package": "electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "10.1.0",
    "react-window": "2.2.7",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "4.0.1",
    "uuid": "13.0.0",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "10.0.0",
    "electron": "34.5.8",
    "electron-builder": "25.1.8",
    "electron-vite": "3.1.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "6.4.1",
    "vitest": "3.2.4"
  }
}
